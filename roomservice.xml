<?xml version="1.0" encoding="UTF-8"?>
<!--
  Local Manifests — Xiaomi Mi 10T (apollo) — PixelOS 16 (sixteen-qpr2)
  ════════════════════════════════════════════════════════════════════════
  IMPORTANT NOTES:
  - PixelOS officially dropped apollo after Android 15 (fifteen branch).
    There is no official sixteen-qpr2 device tree for apollo anywhere.
    We use the last known good (fifteen) trees and build anyway — this is
    common practice. You may hit minor build errors that need patching.
  - apollo (Mi 10T) and apollon (Mi 10T Pro) are DIFFERENT codenames.
    Don't mix them up in vendor paths.
-->

<manifest>

  <!-- ════════════════════════════════════════════════════════════
       REMOTE — REQUIRED. Without this, repo sync crashes instantly
       with "remote github not defined in default.xml"
       ════════════════════════════════════════════════════════════ -->
  <remote
    name="github"
    fetch="https://github.com/" />

  <!-- ════════════════════════════════════════════════════════════
       DEVICE TREES
       Source: PixelOS-Devices-old (archived Jul 2025)
       Best available — no sixteen branch exists for apollo anywhere.
       fifteen branch = Android 15 trees, used as base for Android 16.
       ════════════════════════════════════════════════════════════ -->

  <!-- apollo-specific tree (your exact phone: Mi 10T) -->
  <project
    name="PixelOS-Devices-old/device_xiaomi_apollo"
    path="device/xiaomi/apollo"
    remote="github"
    revision="fifteen"
    clone-depth="1" />

  <!-- sm8250-common (shared Snapdragon 865 config) -->
  <!-- NOTE: NTSync SELinux patches are applied here by build.sh -->
  <project
    name="PixelOS-Devices-old/android_device_xiaomi_sm8250-common"
    path="device/xiaomi/sm8250-common"
    remote="github"
    revision="fifteen"
    clone-depth="1" />

  <!-- ════════════════════════════════════════════════════════════
       VENDOR BLOBS (proprietary drivers from Xiaomi's stock ROM)
       TheMuppets hosts pre-extracted blobs.
       lineage-22.2 = Android 15 blobs — compatible enough for A16.
       ════════════════════════════════════════════════════════════ -->

  <!-- sm8250 common blobs (shared across all kona devices) -->
  <project
    name="TheMuppets/proprietary_vendor_xiaomi_sm8250-common"
    path="vendor/xiaomi/sm8250-common"
    remote="github"
    revision="lineage-22.2"
    clone-depth="1" />

  <!-- apollo-specific blobs (Mi 10T only — NOT apollon/Mi 10T Pro) -->
  <!-- VERIFY: go to github.com/TheMuppets and search "apollo"      -->
  <!-- If proprietary_vendor_xiaomi_apollo doesn't exist there,     -->
  <!-- you'll need to extract blobs yourself from a stock ROM using -->
  <!-- the extract-files.py script in the device tree.              -->
  <project
    name="TheMuppets/proprietary_vendor_xiaomi_apollo"
    path="vendor/xiaomi/apollo"
    remote="github"
    revision="lineage-22.2"
    clone-depth="1" />

  <!-- ════════════════════════════════════════════════════════════
       KERNEL
       LineageOS sm8250 kernel at lineage-22.2 (Android 15 base).
       If you want NTSync, replace this with your E404 kernel fork
       that has the NTSync driver compiled in — otherwise the SELinux
       rules build.sh adds will have nothing to label.
       ════════════════════════════════════════════════════════════ -->

  <!-- OPTION A: LineageOS kernel (no NTSync) — currently active -->
  <project
    name="LineageOS/android_kernel_xiaomi_sm8250"
    path="kernel/xiaomi/sm8250"
    remote="github"
    revision="lineage-22.2"
    clone-depth="1" />

  <!-- OPTION B: Your E404 kernel (has NTSync driver) — uncomment this
       and comment out OPTION A above. Set revision to your NTSync branch.
  <project
    name="kvsnr113/xiaomi_sm8250_kernel_e404"
    path="kernel/xiaomi/sm8250"
    remote="github"
    revision="main"
    clone-depth="1" />
  -->

</manifest>
