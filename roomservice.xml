<?xml version="1.0" encoding="UTF-8"?>
<!--
  Local Manifests for Xiaomi Mi 10T (apollo) — PixelOS 16 (sixteen-qpr2)

  HOW TO USE:
    1. Create a new GitHub repo called "local_manifests_apollo"
    2. Put this file inside it as: roomservice.xml
    3. Push it to GitHub
    4. Update the git clone URL in build.sh with your GitHub username
-->

<manifest>

  <!-- ═══════════════════════════════════════════════════════
       DEVICE TREES
       ═══════════════════════════════════════════════════════ -->

  <project
    name="xiaomi-sm8250-devs/android_device_xiaomi_apollo"
    path="device/xiaomi/apollo"
    remote="github"
    revision="lineage-22"
    clone-depth="1" />

  <project
    name="xiaomi-sm8250-devs/android_device_xiaomi_sm8250-common"
    path="device/xiaomi/sm8250-common"
    remote="github"
    revision="lineage-22"
    clone-depth="1" />

  <!-- ═══════════════════════════════════════════════════════
       VENDOR (proprietary blobs)
       ═══════════════════════════════════════════════════════ -->

  <project
    name="TheMuppets/proprietary_vendor_xiaomi_sm8250-common"
    path="vendor/xiaomi/sm8250-common"
    remote="github"
    revision="lineage-22"
    clone-depth="1" />

  <project
    name="TheMuppets/proprietary_vendor_xiaomi_apollo"
    path="vendor/xiaomi/apollo"
    remote="github"
    revision="lineage-22"
    clone-depth="1" />

  <!-- ═══════════════════════════════════════════════════════
       KERNEL — LineageOS
       ═══════════════════════════════════════════════════════ -->

  <project
    name="LineageOS/android_kernel_xiaomi_sm8250"
    path="kernel/xiaomi/sm8250"
    remote="github"
    revision="lineage-22"
    clone-depth="1" />

  <!-- ═══════════════════════════════════════════════════════
       REMOTE DEFINITIONS
       ═══════════════════════════════════════════════════════ -->

  <remote
    name="github"
    fetch="https://github.com/" />

</manifest>
